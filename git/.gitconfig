# ~/.gitconfig - Git configuration
# https://git-scm.com/docs/git-config

[user]
    name = Duy Nguyen
    email = duy.nguyen@mable.com.au
    signingkey = 1185A8F85D497553

[alias]
    a = add
    aa = add --all
    ap = add --patch
    b = branch
    ba = branch --all
    br = branch --remote
    branches = branch --sort=-committerdate
    ca = commit --amend
    ci = commit
    cm = commit -v
    cl = clone
    co = checkout
    contributors = shortlog --summary --numbered
    df = diff
    dc = diff --cached
    f = fetch
    l = log --date=format:'%b %d, %Y' --pretty=format:'%C(yellow bold)%h%Creset%C(white)%d%Creset %s%n%C(blue)%aN <%ae> | %cd%n'
    lg = log --graph --stat --date=format:'%b %d, %Y' --pretty=format:'%C(yellow bold)%h%Creset%C(white)%d%Creset %s%n%C(blue)%aN <%ae> | %cd%n'
    last = log -1 HEAD
    pl = pull
    ps = push
    psf = push --force-with-lease
    recent = for-each-ref --sort=committerdate refs/heads/ --format='%(HEAD) %(color:yellow)%(refname:short)%(color:reset) - %(color:red)%(objectname:short)%(color:reset) - %(contents:subject) - %(authorname) (%(color:green)%(committerdate:relative)%(color:reset))'
    rv = remote -v
    s = status
    st = status
    tl = tag --list
    re = reset
    rsh = reset --soft HEAD^
    unstage = reset HEAD --
    visual = log --oneline --graph --decorate --all
    wch = whatchanged -p --abbrev-commit --pretty=medium -10

[apply]
    whitespace = nowarn

[color]
    ui = true

[color "branch"]
    current = white bold
    local = yellow
    remote = cyan

[color "diff"]
    frag = cyan bold
    meta = white
    new = green bold
    old = red bold
    commit = yellow bold
    whitespace = red reverse

[color "diff-highlight"]
    oldNormal = red bold
    oldHighlight = red bold 52
    newNormal = green bold
    newHighlight = green bold 22

[color "status"]
    added = green
    changed = yellow
    untracked = cyan

[commit]
    template = ~/.gitmessage
    gpgSign = true

[core]
    autocrlf = input
    excludesfile = ~/.gitignore_global
    ignorecase = false
    safecrlf = warn
    abbrev = 7
    editor = vim

[credential]
    helper = /usr/local/share/gcm-core/git-credential-manager

[credential "https://dev.azure.com"]
    useHttpPath = true

[diff]
    tool = vimdiff3
    submodule = log

[pager]
    diff = diff-so-fancy | less --tabs=4 -RFXS
    log = less -+X

[fetch]
    prune = true

[gpg]
    program = /opt/homebrew/bin/gpg

[include]
    path = ~/.gitconfig.local

[init]
    defaultBranch = main

[merge]
    conflictstyle = diff3
    ff = false

[pull]
    rebase = merges

[push]
    default = simple

[status]
    submoduleSummary = true

[tag]
    gpgSign = true

[help]
    autocorrect = 1

[includeIf "gitdir:~/projects/personal/"]
    path = ~/.gitconfig.d/personal

[includeIf "gitdir:~/projects/mableit/"]
    path = ~/.gitconfig.d/work
